# DeepSeek API Key
# Get your key from: https://platform.deepseek.com/api_keys
# IMPORTANT: Must use NUXT_ prefix for Nuxt to load it
NUXT_DEEPSEEK_API_KEY=sk-xxxxx

# Brave Search API Key
# Get your key from: https://brave.com/search/api/
# Free tier: 2,000 queries/month
# IMPORTANT: Must use NUXT_ prefix for Nuxt to load it
NUXT_BRAVE_SEARCH_API_KEY=BSAxxxxx
